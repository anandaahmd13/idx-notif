# Telegram credentials — get token from @BotFather.
# Add your bot to the target channel as an admin, then set the channel id
# (e.g. @my_idx_channel  or  -1001234567890 for a private channel).
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here
TELEGRAM_CHAT_ID=@your_channel

# Optional: path to config file (defaults to ./config.yaml)
# IDX_CONFIG=config.yaml
